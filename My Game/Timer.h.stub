#pragma once
#include <functional>

class Timer {
public:
    float GetFrameTime() const { return 0.016f; }
    float GetDeltaTime() const { return 0.016f; }
    float GetFPS() const { return 60.0f; }
    void Tick() {} // No-op
    void Tick(float) {} // Overload with parameter
    template<typename Func>
    void Tick(Func f) { f(); } // Execute callback immediately
};
